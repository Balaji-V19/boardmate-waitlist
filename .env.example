# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit it.

# Path to the service-account JSON downloaded from
#   Firebase console → Project Settings → Service Accounts
#   → "Generate new private key".
#
# A relative path is resolved from this project folder when running
# `npm run dev` or `npm run build`:
#
#   GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
#
# Or pass an absolute path if you prefer.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Your Firebase project id.
FIREBASE_PROJECT_ID=boardmate-app

# Public URL of the deployed site (used in share links).
NEXT_PUBLIC_SITE_URL=https://boardmate-app.web.app
