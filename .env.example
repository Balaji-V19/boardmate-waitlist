# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit it.

# Firebase credentials. Use EITHER of the two below — not both.
#
# Option A — local dev (path to a JSON file on disk):
#   The gitignored `firebase-service-account.json` at the project root is the
#   default. Generate it from
#     Firebase console → Project Settings → Service Accounts
#     → "Generate new private key"
#   then point this at it (relative or absolute path).
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Option B — hosted deploy (paste the JSON contents directly).
# Required on Vercel, Render, Cloud Run, etc. where there is no disk to drop
# a file onto. Paste the entire service-account JSON as a single line — most
# host UIs accept newlines fine; if yours doesn't, escape them as \\n.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"boardmate-app",...}

# Your Firebase project id.
FIREBASE_PROJECT_ID=boardmate-app

# Public URL of the deployed site (used in share links and OG tags).
NEXT_PUBLIC_SITE_URL=https://boardmate-app.web.app
